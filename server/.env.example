# Copy this file to .env and fill in your values
# Never commit the actual .env file

PORT=5000

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/zoberry?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Payment gateway (UroPay) bootstrap — managed from the admin panel at /payment-settings
UROPAY_MODE=test
UROPAY_API_KEY=
UROPAY_SECRET=
UROPAY_VPA=
UROPAY_VPA_NAME=Zoberry
